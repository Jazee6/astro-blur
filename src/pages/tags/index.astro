---
import MainLayout from "../../layouts/MainLayout.astro";
import Badge from "../../components/Badge.astro";
import {getCollection} from 'astro:content';
import {getAllTags} from "../../utils/tags";
import {getTitle} from "../../utils";

const posts = await getCollection('posts', ({data}) => {
    return import.meta.env.PROD ? data.isDraft !== true : true
});
const {tags, counts} = getAllTags(posts);
---

<MainLayout title={getTitle("Tags")} description="All tags">
    <div class="grow flex flex-col gap-2">
        <h1 class="text-2xl font-bold p-1">Tags</h1>

        <div class='base-card'>
            {tags.length === 0 ? (
                    <p class="text-secondary">No tags yet.</p>
            ) : (
                    <div class="flex flex-wrap gap-2">
                        {tags.map(tag => (
                                <a href={`/tags/${tag}`} class="">
                                    <Badge icon="material-symbols:tag-rounded">
                                        {tag} ({counts.get(tag) || 0})
                                    </Badge>
                                </a>
                        ))}
                    </div>
            )}
        </div>

    </div>
</MainLayout>
