---
import {siteConfig} from "../config";
import type {CollectionEntry} from 'astro:content';

interface Props {
    post: CollectionEntry<'posts'>;
}

const {post} = Astro.props;
---

<li>
    <a class="relative h-36 card p-4 flex flex-col overflow-hidden"
       href={`/posts/${post.id}`}>
        {post.data.pinned && (
            <div
                class="absolute top-0 right-0 w-0 h-0 border-t-[28px] border-t-primary border-l-[28px] border-l-transparent rounded-tr-xl z-10 pointer-events-none"
                aria-hidden="true"
            />
        )}
        <h2 class="text-xl font-bold line-clamp-1">
            {post.data.title}
        </h2>
        <p class="line-clamp-2">
            {post.data.description}
        </p>
        <div class="mt-auto flex items-center">
            <time class="ml-auto" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(siteConfig.language)}
            </time>
        </div>
    </a>
</li>
